# API Configuration
API_KEY=your_secret_api_key_here
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/validation_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Model Configuration
MODEL_CACHE_DIR=./models
CLIP_MODEL=ViT-B/32
WHISPER_MODEL=base
YOLO_MODEL=yolov8n

# Validation Thresholds
IMAGE_BLUR_THRESHOLD=100.0
IMAGE_CONFIDENCE_THRESHOLD=0.85
TEXT_COMPLETENESS_THRESHOLD=0.7
VOICE_SNR_THRESHOLD=20.0
CLIP_SIMILARITY_THRESHOLD=0.85
TEXT_SIMILARITY_THRESHOLD=0.75

# Performance Configuration
MAX_UPLOAD_SIZE_MB=10
MAX_WORKERS=4
REQUEST_TIMEOUT_SECONDS=30

# Monitoring Configuration
METRICS_PORT=8001
LOG_LEVEL=INFO

# Frontend Configuration
FRONTEND_URL=http://localhost:3001

# LLM Configuration (Research-Grade)
LLM_PROVIDER=mock  # Options: mock, openai, gemini
OPENAI_API_KEY=
GEMINI_API_KEY=AIzaSyDkKb2NWOAgLztMH0gkYNX2PwxZ9VyBTzo
LLM_MODEL=gpt-4-turbo

